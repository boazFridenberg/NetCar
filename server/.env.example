# ──────────────────────────────────────────────────────────────
#  NetCar — Server Environment
#  Copy this file to ".env" and fill in real values.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3002

# CORS — comma-separated list of allowed origins (frontend URLs)
CLIENT_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────
#  MongoDB — primary persistent database (Atlas recommended for production)
#  Local dev default: mongodb://127.0.0.1:27017/netcar
#  Atlas example:     mongodb+srv://<user>:<pass>@cluster.mongodb.net/netcar
# ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/netcar

# Background catalog re-sync cadence in hours (0 disables the scheduler).
CATALOG_SYNC_HOURS=24

# ──────────────────────────────────────────────────────────────
#  JWT — split-token authentication
#  Use long, random strings (e.g. `openssl rand -hex 64`).
#  ACCESS and REFRESH secrets MUST be different.
# ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-me-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-me-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ──────────────────────────────────────────────────────────────
#  Gov.il — Ministry of Transportation open data (data.gov.il CKAN)
#  This resource holds the new private-vehicle registry.
# ──────────────────────────────────────────────────────────────
GOV_API_BASE=https://data.gov.il/api/3/action/datastore_search
GOV_RESOURCE_ID=053cea08-09bc-40ec-8f7a-156f0677aff3
# Importer price list (mehir) — יבואנים ומחירוני רכב חדש
GOV_PRICE_RESOURCE_ID=39f455bf-6db0-4926-859d-017f34eacbcb
# WLTP model specs (nefah_manoa, koah_sus, seats, drivetrain…)
GOV_SPECS_RESOURCE_ID=142afde2-6228-49f9-8a29-9b6c3a0cbe40
GOV_PAGE_SIZE=1000

# ──────────────────────────────────────────────────────────────
#  Google Custom Search (Image mode) — primary image provider
#  https://developers.google.com/custom-search/v1/overview
# ──────────────────────────────────────────────────────────────
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# ──────────────────────────────────────────────────────────────
#  Bing Image Search — secondary fallback provider
#  https://www.microsoft.com/en-us/bing/apis/bing-image-search-api
# ──────────────────────────────────────────────────────────────
BING_IMAGE_KEY=
BING_IMAGE_ENDPOINT=https://api.bing.microsoft.com/v7.0/images/search

# Local silhouette fallback (served by the client). Final safety net.
FALLBACK_IMAGE_URL=/assets/vehicle-silhouette.svg

# Resolved image URLs are cached permanently in MongoDB (image_cache collection),
# so the paid image APIs are hit at most once per Make+Model+Year. Kept for
# backward compatibility; expiry is no longer applied.
IMAGE_CACHE_TTL_MS=86400000

# ──────────────────────────────────────────────────────────────
#  Admin bootstrap — first admin account created on cold start.
# ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@netcar.local
ADMIN_PASSWORD=ChangeMe!2026

# ──────────────────────────────────────────────────────────────
#  SMTP — password reset emails
#  Leave empty in dev to log reset links in the server console.
#  Gmail example: smtp.gmail.com:587 + App Password
# ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NetCar <noreply@netcar.local>
PASSWORD_RESET_TTL=1h
